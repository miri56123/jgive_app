<div class="max-w-5xl mx-auto px-4 py-10">
  <h1 class="text-2xl font-bold text-gray-900 mb-8 text-right">קמפיינים פעילים</h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
    <% @campaigns.each do |campaign| %>
      <%= link_to campaign_path(campaign),
            class: "block bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow" do %>

        <%# Cover image %>
        <div class="relative h-52 bg-gray-200 overflow-hidden">
          <% if campaign.cover_image_url.present? %>
            <img src="<%= campaign.cover_image_url %>"
                 alt="<%= campaign.title %>"
                 class="w-full h-full object-cover">
          <% end %>
          <div class="absolute top-3 end-3 bg-white bg-opacity-80 rounded-full p-1.5">
            <%= render "shared/heart_icon", style: "width:18px;height:18px;display:block" %>
          </div>
        </div>

        <div class="p-4">
          <h2 class="text-base font-bold text-gray-900 text-right leading-snug mb-0.5">
            <%= campaign.title %>
          </h2>
          <p class="text-xs text-gray-400 text-right mb-3">ע"י <%= campaign.organization_name %></p>

          <div class="flex items-baseline justify-end gap-1 mb-2">
            <span class="text-sm text-gray-400">גויס</span>
            <span class="text-xl font-bold text-gray-900 dir-ltr">
              <%= format_amount(campaign.amount_raised) %>
            </span>
          </div>

          <div class="w-full bg-gray-200 rounded-full h-1.5 mb-3">
            <div class="bg-green-500 h-1.5 rounded-full" style="width:<%= campaign.progress_pct %>%"></div>
          </div>

          <div class="flex justify-between text-xs text-gray-400">
            <span><%= number_with_delimiter(campaign.donor_count) %> תורמים</span>
            <span><%= campaign.percent_funded %>% גויס</span>
          </div>
        </div>

      <% end %>
    <% end %>
  </div>
</div>

<% content_for :title, "#{@campaign.title} | Jgive" %>

<div data-controller="modal"
     data-modal-autoopen-value="<%= @donation.errors.any? %>">

<%# Hero Section %>
<div class="relative w-full h-72 md:h-96 bg-gray-800 overflow-hidden">
  <% if @campaign.cover_image_url.present? %>
    <img src="<%= @campaign.cover_image_url %>"
         alt="<%= @campaign.title %>"
         class="w-full h-full object-cover opacity-90">
  <% end %>
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
  <div class="absolute bottom-6 right-6 text-white">
    <h1 class="text-3xl md:text-4xl font-bold drop-shadow"><%= @campaign.title %></h1>
    <% if @campaign.subtitle.present? %>
      <p class="mt-1 text-base md:text-lg text-white/90"><%= @campaign.subtitle %></p>
    <% end %>
  </div>
</div>

<%# Stats Bar %>
<div class="bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-5xl mx-auto px-6 py-5">
    <%
      has_bonus = @campaign.bonus_goal_amount.present?
      raised    = @campaign.amount_raised.to_f
      raise_pct = @campaign.progress_pct
      goal_pct  = @campaign.goal_marker_pct
    %>

    <%# Row 1: big amount (right in RTL) + % label (left in RTL) %>
    <div class="flex items-end justify-between mb-2">
      <div style="direction:ltr; font-size:3.75rem; font-weight:900; color:#166534; line-height:1.1">
        <%= format_amount(raised) %>
      </div>
      <div style="font-size:1.25rem; font-weight:700; color:#1f2937">
        <span style="color:#16a34a"><%= @campaign.percent_funded %>%</span> גויסו
      </div>
    </div>

    <%# Progress bar — LTR: green(raised) | gray(gap to goal) | heart | purple(bonus zone) %>
    <div style="position:relative; width:100%; height:10px; direction:ltr; margin:16px 0">
      <% if has_bonus %>
        <div style="position:absolute;top:0;bottom:0;left:0;width:<%= goal_pct %>%;background:#e5e7eb;border-radius:9999px 0 0 9999px"></div>
        <div style="position:absolute;top:0;bottom:0;left:<%= goal_pct %>%;right:0;background:#a855f7;border-radius:0 9999px 9999px 0"></div>
        <div style="position:absolute;top:0;bottom:0;left:0;width:<%= raise_pct %>%;background:#22c55e;border-radius:9999px"></div>
        <div style="position:absolute;left:<%= raise_pct %>%;top:50%;transform:translate(-50%,-58%);font-size:22px;line-height:1;pointer-events:none">🧡</div>
      <% else %>
        <div style="position:absolute;inset:0;background:#e5e7eb;border-radius:9999px"></div>
        <div style="position:absolute;top:0;bottom:0;left:0;width:<%= raise_pct %>%;background:#22c55e;border-radius:9999px"></div>
        <div style="position:absolute;left:<%= raise_pct %>%;top:50%;transform:translate(-50%,-58%);font-size:22px;line-height:1;pointer-events:none">🧡</div>
      <% end %>
    </div>

    <%# Row 3: stats + donate button (RTL: first=right, last=left) %>
    <div class="flex items-center justify-between mt-4 gap-4">
      <%# RIGHT: donor count %>
      <div class="whitespace-nowrap">
        <span style="font-size:1.1rem; font-weight:600; color:#6b7280">מספר תורמים:</span>
        <span style="font-size:1.25rem; font-weight:800; color:#111827"> <%= number_with_delimiter(@campaign.donor_count) %></span>
      </div>
      <%# CENTER: primary goal %>
      <div class="whitespace-nowrap">
        <span style="font-size:1.1rem; font-weight:600; color:#6b7280">יעד:</span>
        <span style="font-size:1.25rem; font-weight:800; color:#166534; direction:ltr; display:inline-block"><%= format_amount(@campaign.goal_amount) %></span>
      </div>
      <%# LEFT: bonus goal (purple) %>
      <% if has_bonus %>
        <div class="whitespace-nowrap">
          <span style="font-size:1.1rem; font-weight:600; color:#9333ea">יעד בונוס:</span>
          <span style="font-size:1.25rem; font-weight:800; color:#9333ea; direction:ltr; display:inline-block"><%= format_amount(@campaign.bonus_goal_amount) %></span>
        </div>
      <% end %>
      <%# Donate CTA %>
      <button type="button"
              data-action="click->modal#open"
              class="bg-purple-600 text-white font-bold px-8 py-3 rounded-full hover:bg-purple-700 transition text-base shadow shrink-0">
        לתרומה
      </button>
    </div>
  </div>
</div>

<%# Tabs + Content %>
<div class="max-w-5xl mx-auto px-4 mt-6 mb-16" data-controller="tabs">

  <%# Tab buttons %>
  <div class="flex gap-1 border-b border-gray-200 overflow-x-auto" role="tablist">
    <% [
      ["about",        "על הפרויקט"],
      ["donations",    "תרומות אחרונות"],
      ["ambassadors",  "לוח שגרירים"],
      ["groups",       "קבוצות"],
      ["organization", "על העמותה"],
      ["updates",      "עדכונים"]
    ].each_with_index do |(id, label), i| %>
      <button type="button"
              role="tab"
              data-tabs-target="button"
              data-tab="<%= id %>"
              data-action="click->tabs#switch"
              class="tab-btn whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 transition
                     <%= i == 0 ? 'border-purple-600 text-purple-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
        <%= label %>
      </button>
    <% end %>
  </div>

  <%# About the Project %>
  <div id="tab-about" data-tabs-target="panel" class="py-6 prose prose-lg max-w-none text-gray-700 leading-relaxed">
    <% if @campaign.description.present? %>
      <%= sanitize @campaign.description,
            tags: %w[p h2 h3 h4 strong em ul ol li br a blockquote],
            attributes: %w[href class] %>
    <% else %>
      <p class="text-gray-400 italic">אין תיאור זמין</p>
    <% end %>
  </div>

  <%# Recent Donations %>
  <div id="tab-donations" data-tabs-target="panel" class="hidden py-6">
    <% if @recent_donations.any? %>
      <div class="bg-gray-50 rounded-2xl p-5">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <% @recent_donations.each do |d| %>
            <%= render "donations/card", donation: d %>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-gray-400 italic text-center py-12">טרם בוצעו תרומות.</p>
    <% end %>
  </div>

  <%# Ambassador Board — stub %>
  <div id="tab-ambassadors" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">🏅</p>
      <p class="text-lg font-medium text-gray-500">לוח שגרירים</p>
      <p class="text-sm mt-1">בקרוב</p>
    </div>
  </div>

  <%# Groups — stub %>
  <div id="tab-groups" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">👥</p>
      <p class="text-lg font-medium text-gray-500">קבוצות</p>
      <p class="text-sm mt-1">בקרוב</p>
    </div>
  </div>

  <%# About the Organization %>
  <div id="tab-organization" data-tabs-target="panel" class="hidden py-6">
    <h2 class="text-xl font-bold text-gray-800 mb-4">על העמותה</h2>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm space-y-2">
      <p class="text-gray-700 font-semibold text-lg"><%= @campaign.organization_name %></p>
      <p class="text-sm text-gray-500">תרומות לפרויקט זה עשויות להיות מוכרות לצורכי מס בישראל, בארה"ב, בקנדה ובאנגליה, בהתאם לתנאי השימוש של Jgive.</p>
    </div>
  </div>

  <%# Updates — stub %>
  <div id="tab-updates" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">📢</p>
      <p class="text-lg font-medium text-gray-500">עדכונים</p>
      <p class="text-sm mt-1">אין עדכונים כרגע</p>
    </div>
  </div>

</div>

<%# Donation Modal %>
<dialog data-modal-target="dialog"
        data-action="click->modal#backdropClose"
        class="rounded-2xl shadow-2xl overflow-y-auto"
        style="width: calc(100% - 2rem); max-width: 26rem; max-height: 90vh; margin: auto;">
  <div class="bg-white p-6 md:p-8">
    <div class="flex items-center justify-between mb-1">
      <h2 class="text-2xl font-bold text-gray-800">תרמו עכשיו</h2>
      <button type="button"
              data-action="click->modal#close"
              class="text-gray-400 hover:text-gray-600 w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100 transition text-2xl leading-none shrink-0">
        ×
      </button>
    </div>
    <p class="text-gray-500 text-sm mb-6">כל תרומה מסייעת לממש את הפרויקט</p>
    <%= render "donations/form", campaign: @campaign, donation: @donation %>
  </div>
</dialog>

</div>

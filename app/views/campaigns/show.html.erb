<% content_for :title, "#{@campaign.title} | Jgive" %>

<%# Hero Section %>
<div class="relative w-full h-72 md:h-96 bg-gray-800 overflow-hidden">
  <% if @campaign.cover_image_url.present? %>
    <img src="<%= @campaign.cover_image_url %>"
         alt="<%= @campaign.title %>"
         class="w-full h-full object-cover opacity-90">
  <% end %>
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
  <div class="absolute bottom-6 right-6 text-white">
    <h1 class="text-3xl md:text-4xl font-bold drop-shadow"><%= @campaign.title %></h1>
    <% if @campaign.subtitle.present? %>
      <p class="mt-1 text-base md:text-lg text-white/90"><%= @campaign.subtitle %></p>
    <% end %>
  </div>
</div>

<%# Stats Bar %>
<div class="bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-5xl mx-auto px-4 py-4">
    <%# Progress bar %>
    <div class="mb-3">
      <div class="w-full bg-gray-200 rounded-full h-2.5">
        <div class="bg-green-500 h-2.5 rounded-full transition-all"
             style="width: <%= @campaign.percent_funded %>%"></div>
      </div>
    </div>
    <div class="flex flex-wrap gap-6 items-center justify-between">
      <div class="text-center">
        <div class="text-2xl font-bold text-green-600 dir-ltr">
          ₪ <%= number_with_delimiter(@campaign.amount_raised.to_i) %>
        </div>
        <div class="text-xs text-gray-500 mt-0.5">גויסו</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-purple-600"><%= @campaign.percent_funded %>%</div>
        <div class="text-xs text-gray-500 mt-0.5">מהיעד</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-gray-800"><%= number_with_delimiter(@campaign.donor_count) %></div>
        <div class="text-xs text-gray-500 mt-0.5">תורמים</div>
      </div>
      <div class="text-center">
        <div class="text-lg font-semibold text-gray-600">
          יעד: ₪ <%= number_with_delimiter(@campaign.goal_amount.to_i) %>
        </div>
        <% if @campaign.bonus_goal_amount.present? %>
          <div class="text-xs text-gray-400">יעד בונוס: ₪ <%= number_with_delimiter(@campaign.bonus_goal_amount.to_i) %></div>
        <% end %>
      </div>
      <a href="#donation-form"
         class="bg-purple-600 text-white font-bold px-8 py-3 rounded-full hover:bg-purple-700 transition text-base shadow">
        לתרומה
      </a>
    </div>
  </div>
</div>

<%# Tabs + Content %>
<div class="max-w-5xl mx-auto px-4 mt-6" data-controller="tabs">

  <%# Tab buttons %>
  <div class="flex gap-1 border-b border-gray-200 overflow-x-auto" role="tablist">
    <% [
      ["about",        "על הפרויקט"],
      ["donations",    "תרומות אחרונות"],
      ["ambassadors",  "לוח שגרירים"],
      ["groups",       "קבוצות"],
      ["organization", "על העמותה"],
      ["updates",      "עדכונים"]
    ].each_with_index do |(id, label), i| %>
      <button type="button"
              role="tab"
              data-tabs-target="button"
              data-tab="<%= id %>"
              data-action="click->tabs#switch"
              class="tab-btn whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 transition
                     <%= i == 0 ? 'border-purple-600 text-purple-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
        <%= label %>
      </button>
    <% end %>
  </div>

  <%# About the Project %>
  <div id="tab-about" data-tabs-target="panel" class="py-6 prose prose-lg max-w-none text-gray-700 leading-relaxed">
    <% if @campaign.description.present? %>
      <%= sanitize @campaign.description,
            tags: %w[p h2 h3 h4 strong em ul ol li br a blockquote],
            attributes: %w[href class] %>
    <% else %>
      <p class="text-gray-400 italic">אין תיאור זמין</p>
    <% end %>
  </div>

  <%# Recent Donations %>
  <div id="tab-donations" data-tabs-target="panel" class="hidden py-6">
    <h2 class="text-xl font-bold text-gray-800 mb-4">תרומות אחרונות</h2>
    <% if @recent_donations.any? %>
      <ul class="space-y-3">
        <% @recent_donations.each do |d| %>
          <li class="flex items-center justify-between bg-white rounded-xl border border-gray-100 px-5 py-3 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-purple-100 flex items-center justify-center text-purple-700 font-bold text-sm">
                <%= d.display_name&.first&.upcase || "?" %>
              </div>
              <div>
                <div class="font-medium text-gray-800 text-sm"><%= d.display_name %></div>
                <% if d.dedication_message.present? %>
                  <div class="text-xs text-gray-400 mt-0.5 truncate max-w-xs"><%= d.dedication_message %></div>
                <% end %>
              </div>
            </div>
            <div class="text-left">
              <div class="font-bold text-green-600">₪ <%= number_with_delimiter(d.amount.to_i) %></div>
              <div class="text-xs text-gray-400"><%= d.recurring? ? "הוראת קבע" : "חד-פעמי" %></div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-400 italic">טרם בוצעו תרומות.</p>
    <% end %>
  </div>

  <%# Ambassador Board — stub %>
  <div id="tab-ambassadors" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">🏅</p>
      <p class="text-lg font-medium text-gray-500">לוח שגרירים</p>
      <p class="text-sm mt-1">בקרוב</p>
    </div>
  </div>

  <%# Groups — stub %>
  <div id="tab-groups" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">👥</p>
      <p class="text-lg font-medium text-gray-500">קבוצות</p>
      <p class="text-sm mt-1">בקרוב</p>
    </div>
  </div>

  <%# About the Organization %>
  <div id="tab-organization" data-tabs-target="panel" class="hidden py-6">
    <h2 class="text-xl font-bold text-gray-800 mb-4">על העמותה</h2>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm space-y-2">
      <p class="text-gray-700 font-semibold text-lg"><%= @campaign.organization_name %></p>
      <p class="text-sm text-gray-500">תרומות לפרויקט זה עשויות להיות מוכרות לצורכי מס בישראל, בארה"ב, בקנדה ובאנגליה, בהתאם לתנאי השימוש של Jgive.</p>
    </div>
  </div>

  <%# Updates — stub %>
  <div id="tab-updates" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">📢</p>
      <p class="text-lg font-medium text-gray-500">עדכונים</p>
      <p class="text-sm mt-1">אין עדכונים כרגע</p>
    </div>
  </div>

</div>

<%# Donation Form %>
<div id="donation-form" class="max-w-5xl mx-auto px-4 mt-8 mb-16">
  <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 md:p-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-1">תרמו עכשיו</h2>
    <p class="text-gray-500 text-sm mb-6">כל תרומה מסייעת לממש את הפרויקט</p>

    <%= render "donations/form", campaign: @campaign, donation: @donation %>
  </div>
</div>

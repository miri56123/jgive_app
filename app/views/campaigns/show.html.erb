<% content_for :title, "#{@campaign.title} | Jgive" %>

<%# Hero Section %>
<div class="relative w-full h-72 md:h-96 bg-gray-800 overflow-hidden">
  <% if @campaign.cover_image_url.present? %>
    <img src="<%= @campaign.cover_image_url %>"
         alt="<%= @campaign.title %>"
         class="w-full h-full object-cover opacity-90">
  <% end %>
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
  <div class="absolute bottom-6 right-6 text-white">
    <h1 class="text-3xl md:text-4xl font-bold drop-shadow"><%= @campaign.title %></h1>
    <% if @campaign.subtitle.present? %>
      <p class="mt-1 text-base md:text-lg text-white/90"><%= @campaign.subtitle %></p>
    <% end %>
  </div>
</div>

<%# Stats Bar %>
<div class="bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-5xl mx-auto px-6 py-5">
    <%
      has_bonus = @campaign.bonus_goal_amount.present?
      total_bar = (has_bonus ? @campaign.bonus_goal_amount : @campaign.goal_amount).to_f
      raised    = @campaign.amount_raised.to_f
      raise_pct = [(raised / total_bar * 100), 100].min.round(2)
      goal_pct  = has_bonus ? (@campaign.goal_amount.to_f / total_bar * 100).round(2) : nil
    %>

    <%# Row 1: big amount (right in RTL) + % label (left in RTL) %>
    <div class="flex items-end justify-between mb-2">
      <div class="text-4xl font-extrabold text-green-700" style="direction:ltr">
        &#8362; <%= number_with_delimiter(raised.to_i) %>
      </div>
      <div class="text-sm font-semibold text-gray-700">
        <span class="text-green-600 font-bold"><%= @campaign.percent_funded %>%</span> גויסו
      </div>
    </div>

    <%# Progress bar — LTR: green(raised) | gray(gap to goal) | heart | purple(bonus zone) %>
    <div class="relative w-full my-4" style="height:10px; direction:ltr">
      <% if has_bonus %>
        <%# Gray base layer (regular goal zone) %>
        <div class="absolute inset-0 rounded-full bg-gray-200"
             style="width:<%= goal_pct %>%"></div>
        <%# Purple layer (bonus zone, right of goal marker) %>
        <div class="absolute inset-0 bg-purple-500"
             style="left:<%= goal_pct %>%; right:0; border-radius:0 9999px 9999px 0"></div>
        <%# Green fill (amount raised) %>
        <div class="absolute inset-0 bg-green-500"
             style="width:<%= raise_pct %>%; border-radius:9999px 0 0 9999px"></div>
        <%# Orange heart marker at current progress %>
        <div class="absolute" style="left:<%= raise_pct %>%; top:50%; transform:translate(-50%,-58%); font-size:22px; line-height:1; pointer-events:none">🧡</div>
      <% else %>
        <div class="absolute inset-0 rounded-full bg-gray-200"></div>
        <div class="absolute inset-0 rounded-full bg-green-500 transition-all"
             style="width:<%= raise_pct %>%"></div>
      <% end %>
    </div>

    <%# Row 3: stats + donate button (RTL: first=right, last=left) %>
    <div class="flex items-center justify-between mt-3 gap-4">
      <%# RIGHT: donor count %>
      <div class="text-sm whitespace-nowrap">
        <span class="text-gray-500">מספר תורמים:</span>
        <span class="font-bold text-gray-800"> <%= number_with_delimiter(@campaign.donor_count) %></span>
      </div>
      <%# CENTER: primary goal %>
      <div class="text-sm whitespace-nowrap">
        <span class="text-gray-500">יעד:</span>
        <span class="font-bold text-green-700" style="direction:ltr;display:inline-block">&#8362; <%= number_with_delimiter(@campaign.goal_amount.to_i) %></span>
      </div>
      <%# LEFT: bonus goal (purple) %>
      <% if has_bonus %>
        <div class="text-sm whitespace-nowrap">
          <span class="text-purple-600">יעד בונוס:</span>
          <span class="font-bold text-purple-600" style="direction:ltr;display:inline-block">&#8362; <%= number_with_delimiter(@campaign.bonus_goal_amount.to_i) %></span>
        </div>
      <% end %>
      <%# Donate CTA %>
      <a href="#donation-form"
         class="bg-purple-600 text-white font-bold px-8 py-3 rounded-full hover:bg-purple-700 transition text-base shadow shrink-0">
        לתרומה
      </a>
    </div>
  </div>
</div>

<%# Tabs + Content %>
<div class="max-w-5xl mx-auto px-4 mt-6" data-controller="tabs">

  <%# Tab buttons %>
  <div class="flex gap-1 border-b border-gray-200 overflow-x-auto" role="tablist">
    <% [
      ["about",        "על הפרויקט"],
      ["donations",    "תרומות אחרונות"],
      ["ambassadors",  "לוח שגרירים"],
      ["groups",       "קבוצות"],
      ["organization", "על העמותה"],
      ["updates",      "עדכונים"]
    ].each_with_index do |(id, label), i| %>
      <button type="button"
              role="tab"
              data-tabs-target="button"
              data-tab="<%= id %>"
              data-action="click->tabs#switch"
              class="tab-btn whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 transition
                     <%= i == 0 ? 'border-purple-600 text-purple-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
        <%= label %>
      </button>
    <% end %>
  </div>

  <%# About the Project %>
  <div id="tab-about" data-tabs-target="panel" class="py-6 prose prose-lg max-w-none text-gray-700 leading-relaxed">
    <% if @campaign.description.present? %>
      <%= sanitize @campaign.description,
            tags: %w[p h2 h3 h4 strong em ul ol li br a blockquote],
            attributes: %w[href class] %>
    <% else %>
      <p class="text-gray-400 italic">אין תיאור זמין</p>
    <% end %>
  </div>

  <%# Recent Donations %>
  <div id="tab-donations" data-tabs-target="panel" class="hidden py-6">
    <% if @recent_donations.any? %>
      <div class="bg-gray-50 rounded-2xl" style="padding:20px 20px 20px 20px">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <% @recent_donations.each do |d| %>
            <div class="bg-white rounded-2xl shadow-sm flex flex-col" style="padding:20px;min-height:200px">
              <%# Timestamp (left) + Amount (right) %>
              <div class="flex items-start justify-between mb-3">
                <span class="text-3xl font-bold text-gray-900 dir-ltr">₪<%= number_with_delimiter(d.amount.to_i) %></span>
                <span class="text-xs text-gray-400 mt-2"><%= hebrew_time_ago(d.created_at) %></span>
              </div>
              <%# Donor name %>
              <div class="text-sm font-bold text-gray-800 text-right">
                <%= d.display_name %>
                <% if d.dedication_message.present? %>
                  <p class="text-xs text-gray-400 font-normal mt-0.5 truncate"><%= d.dedication_message %></p>
                <% end %>
              </div>
              <%# Push heart to bottom-left %>
              <div class="flex-1"></div>
              <div style="text-align:left">
                <svg style="width:22px;height:22px;display:inline-block" fill="none" stroke="#c084fc" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                </svg>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-gray-400 italic text-center py-12">טרם בוצעו תרומות.</p>
    <% end %>
  </div>

  <%# Ambassador Board — stub %>
  <div id="tab-ambassadors" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">🏅</p>
      <p class="text-lg font-medium text-gray-500">לוח שגרירים</p>
      <p class="text-sm mt-1">בקרוב</p>
    </div>
  </div>

  <%# Groups — stub %>
  <div id="tab-groups" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">👥</p>
      <p class="text-lg font-medium text-gray-500">קבוצות</p>
      <p class="text-sm mt-1">בקרוב</p>
    </div>
  </div>

  <%# About the Organization %>
  <div id="tab-organization" data-tabs-target="panel" class="hidden py-6">
    <h2 class="text-xl font-bold text-gray-800 mb-4">על העמותה</h2>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm space-y-2">
      <p class="text-gray-700 font-semibold text-lg"><%= @campaign.organization_name %></p>
      <p class="text-sm text-gray-500">תרומות לפרויקט זה עשויות להיות מוכרות לצורכי מס בישראל, בארה"ב, בקנדה ובאנגליה, בהתאם לתנאי השימוש של Jgive.</p>
    </div>
  </div>

  <%# Updates — stub %>
  <div id="tab-updates" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">📢</p>
      <p class="text-lg font-medium text-gray-500">עדכונים</p>
      <p class="text-sm mt-1">אין עדכונים כרגע</p>
    </div>
  </div>

</div>

<%# Donation Form %>
<div id="donation-form" class="max-w-5xl mx-auto px-4 mt-8 mb-16">
  <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 md:p-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-1">תרמו עכשיו</h2>
    <p class="text-gray-500 text-sm mb-6">כל תרומה מסייעת לממש את הפרויקט</p>

    <%= render "donations/form", campaign: @campaign, donation: @donation %>
  </div>
</div>

<% content_for :title, "#{@campaign.display_title} | Jgive" %>
<%= turbo_stream_from @campaign %>

<div data-controller="modal"
     data-modal-autoopen-value="<%= @donation.errors.any? %>">

<%# Hero Section %>
<div class="relative w-full h-72 md:h-96 bg-gray-800 overflow-hidden">
  <% if @campaign.cover_image_url.present? %>
    <img src="<%= @campaign.cover_image_url %>"
         alt="<%= @campaign.display_title %>"
         class="w-full h-full object-cover opacity-90">
  <% end %>
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
  <div class="absolute bottom-6 start-6 text-white">
    <h1 class="text-3xl md:text-4xl font-bold drop-shadow"><%= @campaign.display_title %></h1>
    <% if @campaign.display_subtitle.present? %>
      <p class="mt-1 text-base md:text-lg text-white/90"><%= @campaign.display_subtitle %></p>
    <% end %>
  </div>
</div>

<%= render "campaigns/stats", campaign: @campaign %>

<%# Tabs + Content %>
<div class="max-w-5xl mx-auto px-4 mt-6 mb-16" data-controller="tabs">

  <%# Tab buttons %>
  <div class="flex gap-1 border-b border-gray-200 overflow-x-auto" role="tablist">
    <% [
      ["about",        t("campaigns.show.tabs.about")],
      ["donations",    t("campaigns.show.tabs.donations")],
      ["ambassadors",  t("campaigns.show.tabs.ambassadors")],
      ["groups",       t("campaigns.show.tabs.groups")],
      ["organization", t("campaigns.show.tabs.organization")],
      ["updates",      t("campaigns.show.tabs.updates")]
    ].each_with_index do |(id, label), i| %>
      <button type="button"
              role="tab"
              data-tabs-target="button"
              data-tab="<%= id %>"
              data-action="click->tabs#switch"
              class="tab-btn whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 transition
                     <%= i == 0 ? 'border-purple-600 text-purple-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
        <%= label %>
      </button>
    <% end %>
  </div>

  <%# About the Project %>
  <div id="tab-about" data-tabs-target="panel" class="py-6 prose prose-lg max-w-none text-gray-700 leading-relaxed">
    <% if @campaign.display_description.present? %>
      <%= sanitize @campaign.display_description,
            tags: %w[p h2 h3 h4 strong em ul ol li br a blockquote],
            attributes: %w[href class] %>
    <% else %>
      <p class="text-gray-400 italic"><%= t("campaigns.show.no_description") %></p>
    <% end %>
  </div>

  <%# Recent Donations %>
  <div id="tab-donations" data-tabs-target="panel" class="hidden py-6">
    <div id="recent-donations-<%= @campaign.id %>" class="grid grid-cols-2 md:grid-cols-3 gap-6">
      <% @recent_donations.each do |d| %>
        <%= render "donations/card", donation: d %>
      <% end %>
    </div>
  </div>

  <%# Ambassador Board — stub %>
  <div id="tab-ambassadors" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">🏅</p>
      <p class="text-lg font-medium text-gray-500"><%= t("campaigns.show.tabs.ambassadors") %></p>
      <p class="text-sm mt-1"><%= t("campaigns.show.coming_soon") %></p>
    </div>
  </div>

  <%# Groups — stub %>
  <div id="tab-groups" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">👥</p>
      <p class="text-lg font-medium text-gray-500"><%= t("campaigns.show.tabs.groups") %></p>
      <p class="text-sm mt-1"><%= t("campaigns.show.coming_soon") %></p>
    </div>
  </div>

  <%# About the Organization %>
  <div id="tab-organization" data-tabs-target="panel" class="hidden py-6">
    <h2 class="text-xl font-bold text-gray-800 mb-4"><%= t("campaigns.show.tabs.organization") %></h2>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm space-y-2">
      <p class="text-gray-700 font-semibold text-lg"><%= @campaign.display_organization_name %></p>
      <p class="text-sm text-gray-500"><%= t("campaigns.show.tax_notice") %></p>
    </div>
  </div>

  <%# Updates — stub %>
  <div id="tab-updates" data-tabs-target="panel" class="hidden py-6">
    <div class="text-center text-gray-400 py-12">
      <p class="text-4xl mb-3">📢</p>
      <p class="text-lg font-medium text-gray-500"><%= t("campaigns.show.tabs.updates") %></p>
      <p class="text-sm mt-1"><%= t("campaigns.show.no_updates") %></p>
    </div>
  </div>

</div>

<%# Donation Modal %>
<dialog data-modal-target="dialog"
        data-action="click->modal#backdropClose"
        class="rounded-2xl shadow-2xl overflow-y-auto"
        style="width: calc(100% - 2rem); max-width: 26rem; max-height: 90vh; margin: auto;">
  <div class="bg-white p-6 md:p-8">
    <div class="flex items-center justify-between mb-1">
      <h2 class="text-2xl font-bold text-gray-800"><%= t("campaigns.show.modal_title") %></h2>
      <button type="button"
              data-action="click->modal#close"
              class="text-gray-400 hover:text-gray-600 w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100 transition text-2xl leading-none shrink-0">
        ×
      </button>
    </div>
    <p class="text-gray-500 text-sm mb-6"><%= t("campaigns.show.modal_subtitle") %></p>
    <%= render "donations/form", campaign: @campaign, donation: @donation, exchange_rates: @exchange_rates %>
  </div>
</dialog>

</div>

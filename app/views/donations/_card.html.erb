<div class="bg-white rounded-2xl flex flex-col" style="padding:20px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); border: 1px solid #f0f0f0;">
  <%# Amount (right in RTL) + timestamp (left in RTL) %>
  <div class="flex items-start justify-between mb-3">
    <div>
      <span class="text-3xl font-bold text-gray-900" style="direction:ltr;display:inline-block"><%= format_amount(donation.amount, donation.currency) %></span>
      <% if donation.currency != "ILS" %>
        <div class="text-xs text-gray-400 mt-0.5" style="direction:ltr"><%= format_amount(donation.amount * donation.exchange_rate) %></div>
      <% end %>
    </div>
    <span class="text-xs text-gray-400 mt-2 shrink-0"><%= hebrew_time_ago(donation.created_at) %></span>
  </div>

  <%# Donor name + dedication %>
  <div class="text-sm font-bold text-gray-800 text-right">
    <%= donation.display_name %>
    <% if donation.dedication_message.present? %>
      <% msg = donation.dedication_message %>
      <% limit = 80 %>
      <% if msg.length > limit %>
        <p class="text-xs text-gray-400 font-normal mt-0.5" id="ded-<%= donation.id %>">
          <span class="ded-short"><%= msg.first(limit) %>...</span>
          <span class="ded-full hidden"><%= msg %></span>
          <button type="button"
                  class="text-purple-500 hover:underline font-medium"
                  onclick="var p=this.closest('p');p.querySelector('.ded-short').classList.toggle('hidden');p.querySelector('.ded-full').classList.toggle('hidden');this.textContent=this.textContent.trim()==='קרא עוד'?'פחות':'קרא עוד'">קרא עוד</button>
        </p>
      <% else %>
        <p class="text-xs text-gray-400 font-normal mt-0.5"><%= msg %></p>
      <% end %>
    <% end %>
  </div>

  <%# Heart pinned to bottom-left %>
  <div class="flex-1"></div>
  <div style="text-align:left; margin-top:12px">
    <svg style="width:22px;height:22px;display:inline-block" fill="none" stroke="#c084fc" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
    </svg>
  </div>
</div>

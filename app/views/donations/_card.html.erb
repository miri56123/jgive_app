<div class="bg-white rounded-2xl shadow-sm flex flex-col" style="padding:20px;min-height:200px">
  <div class="flex items-start justify-between mb-3">
    <span class="text-3xl font-bold text-gray-900 dir-ltr"><%= format_amount(donation.amount) %></span>
    <span class="text-xs text-gray-400 mt-2"><%= hebrew_time_ago(donation.created_at) %></span>
  </div>
  <div class="text-sm font-bold text-gray-800 text-right">
    <%= donation.display_name %>
    <% if donation.dedication_message.present? %>
      <p class="text-xs text-gray-400 font-normal mt-0.5 truncate"><%= donation.dedication_message %></p>
    <% end %>
  </div>
  <div class="flex-1"></div>
  <div style="text-align:left">
    <svg style="width:22px;height:22px;display:inline-block" fill="none" stroke="#c084fc" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
    </svg>
  </div>
</div>

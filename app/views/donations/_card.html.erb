<div class="bg-white rounded-2xl flex flex-col" style="padding:20px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); border: 1px solid #f0f0f0;">
  <%# Amount (right in RTL) + timestamp (left in RTL) %>
  <div class="flex items-start justify-between mb-3">
    <div>
      <span class="text-3xl font-bold text-gray-900" style="direction:ltr;display:inline-block"><%= format_amount(donation.amount, donation.currency) %></span>
      <% if display_currency != donation.currency %>
        <div class="text-xs text-gray-400 mt-0.5" style="direction:ltr">≈ <%= display_amount(donation.amount_in_ils) %></div>
      <% end %>
    </div>
    <span class="text-xs text-gray-400 mt-2 shrink-0"><%= time_ago(donation.created_at) %></span>
  </div>

  <%# Donor name + dedication %>
  <div class="text-sm font-bold text-gray-800 text-start">
    <%= donation.display_name %>
    <% if donation.dedication_message.present? %>
      <% msg = donation.dedication_message %>
      <% if msg.length > Donation::DEDICATION_DISPLAY_LIMIT %>
        <p class="text-xs text-gray-400 font-normal mt-0.5"
           style="overflow-wrap:break-word;word-break:break-word;"
           data-controller="read-more"
           data-read-more-expand-value="<%= t("donations.card.read_more") %>"
           data-read-more-collapse-value="<%= t("donations.card.read_less") %>">
          <span data-read-more-target="short"><%= msg.first(Donation::DEDICATION_DISPLAY_LIMIT) %>...</span>
          <span data-read-more-target="full" class="hidden"><%= msg %></span>
          <button type="button"
                  class="text-purple-500 hover:underline font-medium"
                  data-action="click->read-more#toggle"
                  data-read-more-target="toggle"><%= t("donations.card.read_more") %></button>
        </p>
      <% else %>
        <p class="text-xs text-gray-400 font-normal mt-0.5" style="overflow-wrap:break-word;word-break:break-word;"><%= msg %></p>
      <% end %>
    <% end %>
  </div>

  <%# Heart pinned to bottom-left %>
  <div class="flex-1"></div>
  <div style="text-align:end; margin-top:12px">
    <%= render "shared/heart_icon", style: "width:22px;height:22px;display:inline-block" %>
  </div>
</div>

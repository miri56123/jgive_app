<!DOCTYPE html>
<html lang="he" dir="rtl">
  <head>
    <title><%= content_for(:title) || "Jgive" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans">
    <%# Flash messages %>
    <% if notice %>
      <div class="fixed top-0 inset-x-0 z-50 bg-green-600 text-white text-center py-3 px-4 text-sm font-medium" id="flash-notice">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="fixed top-0 inset-x-0 z-50 bg-red-600 text-white text-center py-3 px-4 text-sm font-medium" id="flash-alert">
        <%= alert %>
      </div>
    <% end %>

    <%# Navigation %>
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14">
        <div class="flex items-center gap-6 text-sm text-gray-600">
          <span class="text-gray-400">פתרונות</span>
          <span class="text-gray-400">מוצרים</span>
          <span class="text-gray-400">עלינו</span>
        </div>
        <a href="/" class="text-2xl font-bold tracking-tight">
          <span class="text-gray-900">J</span><span class="text-purple-600">give</span>
        </a>
        <div class="flex items-center gap-3">
          <span class="text-sm text-gray-500">HE | ILS</span>
          <a href="/" class="bg-purple-600 text-white text-sm font-semibold px-4 py-2 rounded-full hover:bg-purple-700 transition">
            לתרומה
          </a>
        </div>
      </div>
    </nav>

    <%= yield %>

    <%# Footer %>
    <footer class="bg-gray-100 border-t border-gray-200 mt-16 py-8 text-sm text-gray-500 text-center">
      <p>זכויות יוצרים © Jgive <%= Time.current.year %></p>
    </footer>
  </body>
</html>
